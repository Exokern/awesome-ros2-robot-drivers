{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Exokern/awesome-ros2-robot-drivers/blob/main/data/schema.json",
  "title": "Awesome ROS 2 Robot Drivers Index",
  "type": "object",
  "required": ["schema_version", "reviewed_at", "categories", "entries"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "0.2"
    },
    "reviewed_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "description"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "repo",
          "url",
          "category",
          "description",
          "hardware",
          "ros2_native",
          "source_status",
          "review_status",
          "license",
          "last_checked",
          "notes"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "repo": {
            "type": "string",
            "pattern": "^[^/\\s]+/[^/\\s]+$"
          },
          "url": {
            "type": "string",
            "pattern": "^https://github\\.com/[^/\\s]+/[^/\\s]+$"
          },
          "category": {
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "hardware": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "ros2_native": {
            "type": "boolean"
          },
          "source_status": {
            "enum": ["official", "community", "vendor-adjacent", "legacy"]
          },
          "review_status": {
            "enum": ["candidate", "curated", "legacy", "needs-review"]
          },
          "license": {
            "type": "string",
            "minLength": 1
          },
          "last_checked": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "notes": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
